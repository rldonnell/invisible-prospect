# ── Authentication ──
CRON_SECRET=your-random-secret-string
WEBHOOK_SECRET=your-webhook-auth-token

# ── Audience Lab API (pull-based ingestion) ──
AUDIENCELAB_API_KEY=your-audiencelab-api-key
# JSON map of client_key → AL segment ID
AL_SEGMENTS={"sa-spine":"0d8c23ca-10b9-4ec7-9a08-d37abaf80d02","four-winds":{"pixel":"e1ec1ea9-a4bf-4287-bc60-50fede1efa42","al_cold":"91f6aa7b-ec8e-4863-8f4c-eb12b560fef7"},"tbr":{"pixel":"34e00e2c-6d9c-4d9f-aad1-63ad5b81e7f5","al_cold":"e60ee0f7-3b53-4663-aff6-090915315e57"},"waverly-manor":"80c2a238-3596-453e-979d-fb0094efd70a","dough-babies":"df25a6ad-b040-45ff-bf88-edbab4f92afa","az-breasts":"87c40f83-af78-453b-8a7c-877e6f027277","p5":"d2b2fab3-e255-4edb-a5cf-65dd4fbb5dd5"}

# ── GoHighLevel ──
# Shared/agency-level API key (used as fallback if no per-client key exists)
GHL_API_KEY=your-ghl-agency-api-key
GHL_LOCATION_ID=your-default-ghl-location-id

# ── Per-Client GHL API Keys (sub-account level) ──
# GHL_API_KEY_SA_SPINE=your-sa-spine-api-key
# GHL_API_KEY_AZ_BREASTS=your-az-breasts-api-key
# GHL_API_KEY_FOUR_WINDS=your-four-winds-api-key
# GHL_API_KEY_TBR=your-tbr-api-key
# GHL_API_KEY_WAVERLY_MANOR=your-waverly-manor-api-key

# ── Client Configuration ──
# Comma-separated list of active client keys
ACTIVE_CLIENTS=sa-spine,az-breasts,four-winds,tbr,waverly-manor

# ── Per-Client GHL Location IDs (override default) ──
# GHL_LOCATION_SA_SPINE=loc_xxx
# GHL_LOCATION_AZ_BREASTS=loc_xxx
# GHL_LOCATION_FOUR_WINDS=loc_xxx
# GHL_LOCATION_TBR=loc_xxx
# GHL_LOCATION_WAVERLY_MANOR=loc_xxx

# ── Dashboard Auth ──
DASH_SECRET=your-hmac-signing-secret
DASH_PW_ADMIN=your-admin-password
# APP_URL is used for password reset links in emails
APP_URL=https://visitorid.p5marketing.com

# ── Email (Postmark) ──
POSTMARK_API_TOKEN=your-postmark-server-api-token
EMAIL_FROM=VisitorID <noreply@visitorid.p5marketing.com>

# ── Neon Postgres ──
# Connection string from Neon dashboard (use pooled connection)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
